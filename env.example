# NWO Oracle backend — environment template
#
# IMPORTANT: This file (.env.example) is safe to commit and IS in the repo.
# Your real .env file MUST NOT be committed. Add ".env" to .gitignore.
# Render reads these as environment variables in the dashboard, not from a file.
#
# Copy locally:  cp .env.example .env  (then edit .env, never commit it)
# Render setup:  paste each KEY=value into "Environment" in your service settings

# ─────────────────────────────────────────────────────────────────────────────
# Operator (the scheduler that opens prediction windows on Base)
# ─────────────────────────────────────────────────────────────────────────────

# Markets the operator opens windows for. BTC is now included by default.
OPERATOR_TOKENS=ETH,BTC,STATE

# Timeframes in minutes
OPERATOR_TIMEFRAMES=5,15,30,60

# How long a prediction window lives total (seconds)
WINDOW_DURATION_SEC=399

# How long users can match into the window (seconds, must be < WINDOW_DURATION_SEC)
MATCHING_WINDOW_SEC=300

# Operator wallet private key — SECRET. Funds gas for publish/settle txs.
# Must be a Base mainnet address with ETH. Use a dedicated key, not your personal one.
OPERATOR_PRIVATE_KEY=

# Deployed contract on Base mainnet (verified on Basescan)
CONTRACT_ADDRESS=0x16F2E8003877A8Bdb06dB01c30C7eD236285a035

# RPC endpoint. The free public Base RPC works but is rate-limited.
# For production use Alchemy, QuickNode, or Infura.
BASE_RPC_URL=https://mainnet.base.org

# ─────────────────────────────────────────────────────────────────────────────
# AI models (optional — HuggingFace Inference Endpoints)
# ─────────────────────────────────────────────────────────────────────────────
# Leave blank to use the built-in statistical fallbacks (works fine for testing).
# When set, the backend POSTs OHLCV to your HF endpoint and uses real predictions.
# Deploy a model at https://huggingface.co/inference-endpoints and paste the URL.

# Google TimesFM endpoint URL (e.g. https://xxx.endpoints.huggingface.cloud)
HF_TIMESFM_URL=

# NeoQuasar Kronos endpoint URL
HF_KRONOS_URL=

# HuggingFace API token — required if any HF_*_URL is set
# Generate at https://huggingface.co/settings/tokens (read scope is enough)
HF_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────

# Port Render binds. Render sets this automatically; leave blank locally for 5000.
PORT=
